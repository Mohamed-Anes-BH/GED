{
  "name": "ged-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "AgrOdiv GED desktop application",
  "homepage": "https://agrodiv.dz",
  "author": {
    "name": "AgrOdiv",
    "email": "support@agrodiv.dz"
  },
  "desktopName": "AgrOdiv GED",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.agrodiv.ged",
    "productName": "AgrOdiv GED",
    "icon": "public/images/agrodiv-logo.png",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Office",
      "maintainer": "AgrOdiv <support@agrodiv.dz>",
      "synopsis": "Gestion electronique des documents",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": "nsis"
    }
  }
}
